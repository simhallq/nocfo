[Unit]
Description=Frey OpenClaw Gateway
After=frey-fortnox.service docker.service
Requires=docker.service

[Service]
Type=simple
WorkingDirectory=/root/frey/docker
EnvironmentFile=/root/frey/docker/.env
ExecStart=/usr/bin/docker compose up
ExecStop=/usr/bin/docker compose down
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
