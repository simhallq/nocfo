# OpenClaw Docker image (default: official ghcr image)
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# API keys
ANTHROPIC_API_KEY=

# OpenClaw gateway authentication token (generate with: openssl rand -hex 32)
OPENCLAW_GATEWAY_TOKEN=

# Telegram bot token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Fortnox service API token (must match BROWSER_API_TOKEN in services/fortnox/.env)
FORTNOX_API_TOKEN=

# Gateway network binding (lan = bind inside container network)
OPENCLAW_GATEWAY_BIND=lan

# Persistent OpenClaw state (sessions, pairing, agent data)
OPENCLAW_CONFIG_DIR=./data/openclaw

# Workspace and skills paths
FREY_WORKSPACE_DIR=../workspace
FREY_SKILLS_DIR=../skills
