# Fortnox OAuth2 credentials
# Register at: https://apps.fortnox.se/integration-developer/signup
# Create a "Private Integration" with redirect URI: http://localhost:8888/callback
# Scopes: bookkeeping supplierinvoice invoice payment settings companyinformation customer supplier inbox connectfile
FORTNOX_CLIENT_ID=
FORTNOX_CLIENT_SECRET=

# Anthropic API key for web agent (Claude)
ANTHROPIC_API_KEY=

# Database path (default: data/nocfo.db)
DATABASE_PATH=data/nocfo.db

# Log level
LOG_LEVEL=INFO

# Workflow recorder output directory
WORKFLOWS_DIR=data/workflows

# Browser API settings
# URL and token for the local browser automation server
BROWSER_API_URL=http://localhost:8790
BROWSER_API_TOKEN=
BROWSER_CDP_PORT=9222
BROWSER_PROFILE_DIR=data/browser_profile

# Vision fallback & evidence settings
VISION_FALLBACK_ENABLED=true
SCREENSHOTS_DIR=data/screenshots
LEARNED_SELECTORS_PATH=data/learned_selectors.json
